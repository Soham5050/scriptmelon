# ASR - faster, still accurate enough
TRANSCRIBE_BACKEND=faster_whisper
FASTER_WHISPER_MODEL=large-v3
FASTER_WHISPER_BEAM_SIZE=5
FASTER_WHISPER_BEST_OF=2
FASTER_WHISPER_COMPUTE_TYPE=float16
FASTER_WHISPER_CONDITION_ON_PREVIOUS_TEXT=true

# Audio preprocessing - keep yours, it's good
ASR_AUDIO_PREPROCESS_ENABLED=true
ASR_AUDIO_FILTER=highpass=f=90,lowpass=f=7600,afftdn=nf=-20,loudnorm=I=-16:LRA=11:TP=-1.5
ASR_MIN_AVG_LOGPROB=-1.1
ASR_REFINE_LOW_CONF_SEGMENTS_ENABLED=true
ASR_REFINE_MAX_SEGMENTS=8
ASR_REFINE_MARGIN_SEC=0.25
ASR_SKIP_SUSPICIOUS_SEGMENTS=false
ASR_SKIP_SUSPICIOUS_MAX_RATIO=0.25

# Translation - switch to google, save ALL vram for TTS
TRANSLATION_BACKEND=google
TRANSLATION_ENABLE_SMART_ROUTING=false

# TTS sync - tighten the speed clamp
TTS_DURATION_MATCH_MIN_SPEED=0.75
TTS_DURATION_MATCH_MAX_SPEED=1.45
TTS_DURATION_MATCH_EN_MAX_SPEED=1.50
TTS_DURATION_LOCK_ENABLED=true
TTS_DURATION_LOCK_TOLERANCE_SEC=0.06
TTS_DURATION_FORCE_EXACT_FIT=true

# TTS - THIS is where your 99 mins was hiding
TTS_BACKEND=qwen3
QWEN3_LOCAL_MODEL_ID=.\Qwen3-TTS-12Hz-1.7B-Base
QWEN3_LOCAL_DEVICE=cuda:0
QWEN3_LOCAL_DTYPE=bfloat16
QWEN3_LOCAL_USE_FLASH_ATTN=false
QWEN3_USE_REF_TEXT=false
QWEN3_LOCAL_TEMPERATURE=0.78
QWEN3_EXPRESSIVE_ENGLISH_ENABLED=true
QWEN3_EXPRESSIVE_ENGLISH_BOOST=0.08

# THE KEY FIXES:
QWEN3_LOCAL_MAX_CHARS_PER_CHUNK=45
QWEN3_LOCAL_MAX_NEW_TOKENS=512
QWEN3_CPU_MAX_CHARS_PER_CHUNK=120
TTS_MIN_FREE_VRAM_GB=1.8
TTS_SPEAKER_REF_MAX_SECONDS=6.0
TTS_UNLOAD_MODEL_BETWEEN_CHUNKS=false

# GPU memory - tell it your card is low VRAM so it uses conservative profile
ADAPTIVE_RUNTIME_ENABLED=true
GPU_MEMORY_FRACTION=0.80
LOW_VRAM_THRESHOLD_GB=9
MID_VRAM_THRESHOLD_GB=14
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:64

# Misc
HF_TOKEN=your_huggingface_token
WHISPERX_DIARIZE_ENABLED=false
TRANSLATION_STRICT_QUALITY=true
TTS_REF_TEXT=This is a sample voice reference for cloning.

